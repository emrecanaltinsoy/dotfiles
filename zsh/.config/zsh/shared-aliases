## PYTHON
# JupyterLab
jlab() {
  if uv tool list | grep -q jupyterlab; then
    uv run --with jupyter jupyter lab --no-browser
  else
    echo "jupyterlab is not installed. Install it with: uv tool install jupyterlab"
  fi
}

## TMUX
# Tmux Switch Client with FZF
tsc() {
  if [ "$TERM_PROGRAM" = tmux ]; then
    tmux display-popup -E '
      SELECTED_SESSION=$(tmux list-sessions -F "#{session_name}" | fzf)
      if [ -n "$SELECTED_SESSION" ]; then
        tmux display-message "Selected session: $SELECTED_SESSION"
        tmux switch-client -t $SELECTED_SESSION
      fi
    '
  else
    SELECTED_SESSION=$(tmux list-sessions -F "#{session_name}" | fzf)
    if [ -n "$SELECTED_SESSION" ]; then
      tmux attach -t $SELECTED_SESSION
    fi
  fi
}

