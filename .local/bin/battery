#!/bin/sh

# Prints all batteries, their percentage remaining and an emoji corresponding
# to charge status (’ć” for plugged up, ’ēĆ for discharging on battery, etc.).

case $BLOCK_BUTTON in
	3) notify-send "’ēĆ  Battery module" "’ēĆ  : discharging
’ü▒  : not charging
’åĖ  : stagnant charge
’ć”  : charging
’ā¦  : charged
’ēä  : battery very low!" ;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

# acpi alternative
# acpi | sed "s/Battery [0-9]: //;s/[Dd]ischarging, /’ēĆ/;s/[Nn]ot charging, /’ü▒/;s/[Cc]harging, /’ć”/;s/[Uu]nknown, /’åĖ/;s/[Ff]ull, / ’ā¦ /;s/ \(remaining\|until charged\)//"; exit

# Loop through all attached batteries.
for battery in /sys/class/power_supply/BAT?
do
	# Get its remaining capacity and charge status.
	capacity=$(cat "$battery"/capacity) || break
	status=$(sed "s/[Dd]ischarging/’ēĆ/;s/[Nn]ot charging/’ü▒/;s/[Cc]harging/’ć”/;s/[Uu]nknown/’åĖ/;s/[Ff]ull/’ā¦/" "$battery"/status)

	# If it is discharging and 25% or less, we will add a ’ēä as a warning.
	 [ "$capacity" -le 25 ] && [ "$status" = "’ēĆ" ] && warn="’ēä"

	printf "%s%s%s%%\n" "$status" "$warn" " $capacity"
	unset warn
done | sed 's/ *$//'
